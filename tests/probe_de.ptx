    cvt.rzi.s64.f64 %rd1, %fd0;
    cvt.s32.s64 %r1, %rd1;
    cvt.rn.f32.s32 %f0, %r1;
    cvt.f64.f32 %fd0, %f0;
    shl.b32 %r0, %r2, 2;
    cvt.s64.s32 %rd4, %r0;
