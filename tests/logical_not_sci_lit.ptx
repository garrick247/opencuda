    @%p1 mov.s32 %r0, 1;
    @!%p1 mov.s32 %r0, 0;
    shl.b32 %r1, %r2, 2;
    cvt.s64.s32 %rd4, %r1;
    add.u64 %rd1, %rd0, %rd4;
    mul.f32 %f1, %f0, 0f437A0000;
    add.f32 %f2, %f1, 0f38D1B717;
    setp.ne.s32 %p2, %r0, 0;
    @%p2 mov.f32 %f1, 0f3AC49BA6;
    @!%p2 mov.f32 %f1, %f2;
