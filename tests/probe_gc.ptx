    mov.s32 %r0, %r4;
    bra land_merge_10;
land_skip_9:
    mov.s32 %r0, 0;
    bra land_merge_10;
land_merge_10:
    setp.ne.s32 %p2, %r0, 0;
    @%p2 bra if_true_11;
    bra if_merge_13;
if_true_11:
