    cvt.s64.s32 %rd6, %r1;
    add.u64 %rd2, %rd1, %rd6;
    add.s32 %r0, %r2, 1;
    rem.s32 %r1, %r0, 256;
    shl.b32 %r2, %r1, 2;
    cvt.s64.s32 %rd7, %r2;
    add.u64 %rd3, %rd0, %rd7;
