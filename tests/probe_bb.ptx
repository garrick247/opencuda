    add.u64 %rd0, %rd1, 12;
    ld.global.f32 %f3, [%rd0];
    add.u64 %rd0, %rd1, 16;
    ld.global.f32 %f4, [%rd0];
    add.u64 %rd0, %rd1, 20;
    ld.global.f32 %f5, [%rd0];
    add.u64 %rd0, %rd1, 24;
    ld.global.f32 %f6, [%rd0];
    add.u64 %rd0, %rd1, 28;
    ld.global.f32 %f7, [%rd0];
    add.f32 %f8, %f0, %f1;
    add.f32 %f0, %f8, %f2;
    add.f32 %f1, %f0, %f3;
    add.f32 %f2, %f1, %f4;
    add.f32 %f8, %f2, %f5;
    add.f32 %f3, %f8, %f6;
    add.f32 %f0, %f3, %f7;
    bra inline_sum8_merge_5;
if_merge_4:
    ret;
inline_sum8_merge_5:
    st.global.f32 [%rd2], %f0;
    bra if_merge_4;
}
