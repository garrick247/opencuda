.version 9.0
.target sm_120
.address_size 64

.visible .entry atomic_copy_fold(
    .param .u64 counter, .param .u64 data, .param .s32 n)
{
    .reg .b32 %r<2>;
    .reg .b64 %rd<4>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [counter];
    ld.param.u64 %rd1, [data];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    setp.lt.u32 %p0, %r1, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    shl.b32 %r0, %r1, 2;
    cvt.u64.u32 %rd3, %r0;
    add.u64 %rd2, %rd1, %rd3;
    ld.global.s32 %r1, [%rd2];
    atom.global.add.s32 %r0, [%rd0], %r1;
    bra if_merge_4;
if_merge_4:
    ret;
}
