    @%p0 bra tern_true_5;
    bra tern_false_6;
if_merge_4:
    ret;
tern_true_5:
    mov.f32 %f1, %f0;
    bra tern_merge_7;
tern_false_6:
    mov.f32 %f1, 0f00000000;
    bra tern_merge_7;
tern_merge_7:
    st.global.f32 [%rd2], %f1;
    shl.b32 %r4, %r3, 2;
    cvt.s64.s32 %rd5, %r4;
    add.u64 %rd3, %rd1, %rd5;
    sub.f32 %f1, 0f00000000, %f0;
    mul.f32 %f3, %f1, 0f3FB8AA3B;
    ex2.approx.f32 %f2, %f3;
    add.f32 %f1, 0f3F800000, %f2;
    div.approx.f32 %f2, %f0, %f1;
    st.global.f32 [%rd3], %f2;
    bra if_merge_4;
}

.visible .entry bilerp_kernel(
