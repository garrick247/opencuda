    add.s32 %r1, %r0, 1;
    shl.b32 %r0, %r1, 2;
    cvt.s64.s32 %rd4, %r0;
    add.u64 %rd2, %rd1, %rd4;
    ld.global.f32 %f1, [%rd2];
    shl.b32 %r1, %r2, 2;
    cvt.s64.s32 %rd5, %r1;
    add.u64 %rd1, %rd0, %rd5;
    add.f32 %f2, %f0, %f1;
    st.global.f32 [%rd1], %f2;
    bra if_merge_4;
if_merge_4:
    ret;
}

.visible .entry short_char_test(
    .param .u64 out, .param .u64 in, .param .s32 n)
{
    .reg .b32 %r<6>;
    .reg .b64 %rd<3>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [in];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    cvt.s32.u32 %r2, %r1;
    setp.lt.s32 %p0, %r2, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    shl.b32 %r0, %r2, 2;
    cvt.s64.s32 %rd2, %r0;
    add.u64 %rd1, %rd1, %rd2;
    ld.global.s32 %r1, [%rd1];
    cvt.s16.s32 %r2, %r1;
    add.s32 %r1, %r2, 1;
    cvt.u16.s16 %r3, %r1;
    and.b32 %r1, %r3, 127;
    cvt.s8.u16 %r4, %r1;
    add.s32 %r1, %r4, 1;
    cvt.u8.s8 %r5, %r1;
    add.u64 %rd0, %rd0, %rd2;
    cvt.s32.s16 %r0, %r2;
    cvt.s32.u16 %r1, %r3;
    add.s32 %r2, %r0, %r1;
    cvt.s32.s8 %r3, %r4;
    add.s32 %r0, %r2, %r3;
    cvt.s32.u8 %r1, %r5;
    add.s32 %r4, %r0, %r1;
    st.global.s32 [%rd0], %r4;
    bra if_merge_4;
if_merge_4:
    ret;
}
