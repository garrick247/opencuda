.version 9.0
.target sm_120
.address_size 64

.visible .entry integrate(
    .param .u64 particles, .param .f32 dt, .param .s32 n)
{
    .reg .f32 %f<4>;
    .reg .b32 %r<3>;
    .reg .b64 %rd<5>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [particles];
    ld.param.f32 %f3, [dt];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    cvt.s32.u32 %r2, %r1;
    setp.lt.s32 %p0, %r2, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    mul.lo.s32 %r0, %r2, 28;
    cvt.s64.s32 %rd3, %r0;
    add.u64 %rd1, %rd0, %rd3;
    add.u64 %rd2, %rd1, 24;
    ld.global.f32 %f3, [%rd2];
    bra inline_vec3_add_merge_7;
if_merge_4:
    ret;
inline_vec3_add_merge_7:
    mul.lo.s32 %r1, %r2, 28;
    cvt.s64.s32 %rd4, %r1;
    add.u64 %rd1, %rd0, %rd4;
    st.global.f32 [%rd1], %f0;
    add.u64 %rd2, %rd1, 4;
    st.global.f32 [%rd2], %f1;
    add.u64 %rd2, %rd1, 8;
    st.global.f32 [%rd2], %f2;
    bra if_merge_4;
}
