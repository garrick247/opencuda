.version 9.0
.target sm_120
.address_size 64

.visible .entry half_test(
    .param .u64 out, .param .u64 a)
{
    .reg .f32 %f<1>;
    .reg .f16 %h<1>;
    .reg .b32 %r<2>;
    .reg .b64 %rd<5>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [a];
    mov.u32 %r0, %tid.x;
    shl.b32 %r1, %r0, 1;
    cvt.u64.u32 %rd3, %r1;
    add.u64 %rd2, %rd1, %rd3;
    ld.global.b16 %h0, [%rd2];
    shl.b32 %r1, %r0, 2;
    cvt.u64.u32 %rd4, %r1;
    add.u64 %rd1, %rd0, %rd4;
    cvt.f32.f16 %f0, %h0;
    st.global.f32 [%rd1], %f0;
    ret;
}
