}

.visible .entry kernel_c(
    .param .u64 out, .param .s32 n)
{
    .reg .b32 %r<4>;
    .reg .b64 %rd<1>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.s32 %r0, [n];
    mov.s32 %r1, 0;
    mov.s32 %r2, 0;
    bra for_cond_2;
for_cond_2:
    setp.lt.s32 %p0, %r2, %r0;
    @%p0 bra for_body_3;
    bra for_exit_5;
for_body_3:
    add.s32 %r3, %r1, %r2;
    mov.s32 %r1, %r3;
    bra for_inc_4;
for_inc_4:
    add.s32 %r3, %r2, 1;
    mov.s32 %r2, %r3;
    bra for_cond_2;
for_exit_5:
