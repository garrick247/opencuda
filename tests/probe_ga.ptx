.version 9.0
.target sm_120
.address_size 64

.visible .entry shl64_with_s32_amt(
    .param .u64 out, .param .u64 in, .param .u64 amounts, .param .s32 n)
{
    .reg .b32 %r<3>;
    .reg .b64 %rd<6>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [in];
    ld.param.u64 %rd2, [amounts];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    cvt.s32.u32 %r2, %r1;
    setp.lt.s32 %p0, %r2, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    shl.b32 %r0, %r2, 3;
    cvt.s64.s32 %rd4, %r0;
    add.u64 %rd3, %rd1, %rd4;
    ld.global.s64 %rd1, [%rd3];
    shl.b32 %r1, %r2, 2;
    cvt.s64.s32 %rd5, %r1;
    add.u64 %rd3, %rd2, %rd5;
    ld.global.s32 %r2, [%rd3];
    and.b32 %r1, %r2, 63;
    add.u64 %rd2, %rd0, %rd4;
    shl.b64 %rd3, %rd1, %r1;
    st.global.s64 [%rd2], %rd3;
    bra if_merge_4;
if_merge_4:
    ret;
}

