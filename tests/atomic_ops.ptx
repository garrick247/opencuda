.version 9.0
.target sm_120
.address_size 64

.visible .entry atomic_ops_test(
    .param .u64 flags, .param .u64 ubuf, .param .s32 n)
{
    .reg .b32 %r<3>;
    .reg .b64 %rd<2>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [flags];
    ld.param.u64 %rd1, [ubuf];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    cvt.s32.u32 %r2, %r1;
    setp.lt.s32 %p0, %r2, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    atom.global.add.s32 %r0, [%rd0], 1;
    atom.global.min.s32 %r1, [%rd0], %r2;
    atom.global.max.s32 %r0, [%rd0], %r2;
    cvt.u32.s32 %r1, %r2;
    atom.global.and.b32 %r0, [%rd1], %r1;
    atom.global.or.b32 %r2, [%rd1], %r1;
    atom.global.xor.b32 %r0, [%rd1], %r1;
    atom.global.exch.b32 %r2, [%rd0], 0;
    atom.global.cas.b32 %r1, [%rd0], 0, 1;
    bra if_merge_4;
if_merge_4:
    ret;
}
