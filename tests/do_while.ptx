.version 9.0
.target sm_120
.address_size 64

.visible .entry count_down(
    .param .u64 result, .param .s32 n)
{
    .reg .b32 %r<5>;
    .reg .b64 %rd<3>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [result];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    mov.u32 %r2, %ctaid.x;
    mov.u32 %r3, %ntid.x;
    mul.lo.u32 %r4, %r2, %r3;
    add.u32 %r2, %r1, %r4;
    mov.s32 %r3, 0;
    bra do_body_2;
do_body_2:
    add.s32 %r1, %r3, 1;
    sub.s32 %r4, %r0, 1;
    mov.s32 %r3, %r1;
    mov.s32 %r0, %r4;
    bra do_cond_3;
do_cond_3:
    setp.gt.s32 %p0, %r0, 0;
    @%p0 bra do_body_2;
    bra do_exit_4;
do_exit_4:
    shl.b32 %r0, %r2, 2;
    cvt.u64.u32 %rd2, %r0;
    add.u64 %rd1, %rd0, %rd2;
    st.global.s32 [%rd1], %r3;
    ret;
}
