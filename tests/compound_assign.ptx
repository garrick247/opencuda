.version 9.0
.target sm_120
.address_size 64

.visible .entry compound_ops(
    .param .u64 data, .param .s32 n)
{
    .reg .b32 %r<5>;
    .reg .b64 %rd<3>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [data];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    mov.u32 %r2, %ctaid.x;
    mov.u32 %r3, %ntid.x;
    mul.lo.u32 %r4, %r2, %r3;
    add.u32 %r2, %r1, %r4;
    setp.ge.u32 %p0, %r2, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    ret;
if_merge_4:
    shl.b32 %r3, %r2, 2;
    cvt.u64.u32 %rd2, %r3;
    add.u64 %rd1, %rd0, %rd2;
    ld.global.s32 %r0, [%rd1];
    add.s32 %r1, %r0, 10;
    sub.s32 %r4, %r1, 3;
    shl.b32 %r2, %r4, 1;
    and.b32 %r3, %r2, 255;
    or.b32 %r0, %r3, 256;
    xor.b32 %r1, %r0, 85;
    shl.b32 %r4, %r1, 2;
    shr.s32 %r2, %r4, 1;
    st.global.s32 [%rd1], %r2;
    ret;
}
