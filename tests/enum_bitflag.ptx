.version 9.0
.target sm_120
.address_size 64

.visible .entry bitflag_test(
    .param .u64 out, .param .u64 events, .param .s32 n)
{
    .reg .b32 %r<5>;
    .reg .b64 %rd<3>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [events];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    cvt.s32.u32 %r2, %r1;
    setp.lt.s32 %p0, %r2, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    shl.b32 %r0, %r2, 2;
    cvt.s64.s32 %rd2, %r0;
    add.u64 %rd1, %rd1, %rd2;
    ld.global.s32 %r1, [%rd1];
    and.b32 %r2, %r1, 3;
    setp.ne.s32 %p0, %r2, 0;
    selp.s32 %r2, 1, 0, %p0;
    and.b32 %r3, %r1, 4;
    setp.ne.s32 %p0, %r3, 0;
    selp.s32 %r3, 1, 0, %p0;
    and.b32 %r4, %r1, 255;
    add.u64 %rd0, %rd0, %rd2;
    mul.lo.s32 %r0, %r2, 100;
    mul.lo.s32 %r1, %r3, 10;
    add.s32 %r2, %r0, %r1;
    and.b32 %r3, %r4, 15;
    add.s32 %r0, %r2, %r3;
    st.global.s32 [%rd0], %r0;
    bra if_merge_4;
if_merge_4:
    ret;
}
