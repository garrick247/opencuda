.visible .entry bit_ops_chain(
    .param .u64 out, .param .u64 a, .param .u64 b, .param .u64 c, .param .s32 n)
{
    .reg .b32 %r<7>;
    .reg .b64 %rd<6>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [a];
    ld.param.u64 %rd2, [b];
    ld.param.u64 %rd3, [c];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    cvt.s32.u32 %r2, %r1;
    setp.lt.s32 %p0, %r2, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    shl.b32 %r0, %r2, 2;
    cvt.s64.s32 %rd5, %r0;
    add.u64 %rd4, %rd1, %rd5;
    ld.global.s32 %r1, [%rd4];
    add.u64 %rd1, %rd2, %rd5;
    ld.global.s32 %r2, [%rd1];
    add.u64 %rd4, %rd3, %rd5;
    ld.global.s32 %r3, [%rd4];
    xor.b32 %r4, %r1, -1;
    or.b32 %r5, %r2, %r3;
    and.b32 %r6, %r4, %r5;
    xor.b32 %r4, %r1, %r2;
    xor.b32 %r5, %r4, %r3;
    shl.b32 %r2, %r1, 2;
    shr.s32 %r3, %r1, 1;
    add.u64 %rd2, %rd0, %rd5;
    add.s32 %r4, %r6, %r5;
    add.s32 %r0, %r4, %r2;
    add.s32 %r1, %r0, %r3;
    st.global.s32 [%rd2], %r1;
    bra if_merge_4;
if_merge_4:
    ret;
}

