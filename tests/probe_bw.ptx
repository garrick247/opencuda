    cvt.s32.u32 %r5, %r4;
    mov.u32 %r3, %tid.y;
    mov.u32 %r6, %ctaid.y;
    mov.u32 %r4, %ntid.y;
    mul.lo.u32 %r7, %r6, %r4;
    add.u32 %r6, %r3, %r7;
    cvt.s32.u32 %r4, %r6;
    mov.u32 %r3, %tid.z;
    mov.u32 %r7, %ctaid.z;
    mov.u32 %r6, %ntid.z;
    mul.lo.u32 %r8, %r7, %r6;
    add.u32 %r7, %r3, %r8;
    cvt.s32.u32 %r6, %r7;
    setp.lt.s32 %p0, %r5, %r0;
    @%p0 bra land_rhs_2;
    bra land_skip_3;
land_rhs_2:
    setp.lt.s32 %p0, %r4, %r1;
    selp.s32 %r9, 1, 0, %p0;
    mov.s32 %r3, %r9;
    bra land_merge_4;
land_skip_3:
    mov.s32 %r3, 0;
    bra land_merge_4;
land_merge_4:
    setp.ne.s32 %p1, %r3, 0;
    @%p1 bra land_rhs_5;
    bra land_skip_6;
land_rhs_5:
    setp.lt.s32 %p0, %r6, %r2;
    selp.s32 %r10, 1, 0, %p0;
    mov.s32 %r8, %r10;
    bra land_merge_7;
land_skip_6:
    mov.s32 %r8, 0;
    bra land_merge_7;
land_merge_7:
    setp.ne.s32 %p2, %r8, 0;
    @%p2 bra if_true_8;
    bra if_merge_10;
if_true_8:
    mul.lo.s32 %r7, %r4, %r0;
    add.s32 %r2, %r5, %r7;
    mul.lo.s32 %r3, %r6, %r0;
    mul.lo.s32 %r8, %r3, %r1;
    add.s32 %r4, %r2, %r8;
    shl.b32 %r5, %r4, 2;
    cvt.s64.s32 %rd2, %r5;
    add.u64 %rd1, %rd0, %rd2;
    st.global.s32 [%rd1], %r4;
    bra if_merge_10;
if_merge_10:
    ret;
}

