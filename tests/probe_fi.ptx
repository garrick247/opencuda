    ld.global.f32 %f5, [%rd1];
    add.u64 %rd2, %rd1, 4;
    ld.global.f32 %f6, [%rd2];
    ld.global.f32 %f7, [%rd2];
    mov.s32 %r1, 2;
    bra for_cond_10;
for_cond_10:
    shl.b32 %r2, %r0, 1;
    setp.lt.s32 %p0, %r1, %r2;
    @%p0 bra for_body_11;
    bra inline_compute_bbox_merge_5;
for_body_11:
    shl.b32 %r3, %r1, 2;
    cvt.s64.s32 %rd3, %r3;
    add.u64 %rd2, %rd1, %rd3;
    ld.global.f32 %f8, [%rd2];
    add.s32 %r3, %r1, 1;
    shl.b32 %r4, %r3, 2;
    cvt.s64.s32 %rd4, %r4;
    add.u64 %rd2, %rd1, %rd4;
    ld.global.f32 %f9, [%rd2];
    setp.lt.f32 %p0, %f8, %f4;
