    cvt.s64.s32 %rd5, %r1;
    add.u64 %rd1, %rd2, %rd5;
    ld.global.s16 %r1, [%rd1];
    add.s32 %r3, %r0, %r1;
    cvt.s32.s8 %r4, %r3;
    mul.lo.s32 %r3, %r0, %r1;
    cvt.s32.s8 %r5, %r3;
    cvt.s32.s8 %r3, %r0;
    cvt.s32.s16 %r0, %r1;
    add.s32 %r1, %r3, %r0;
    shl.b32 %r3, %r2, 2;
    cvt.s64.s32 %rd6, %r3;
    add.u64 %rd3, %rd0, %rd6;
    add.s32 %r0, %r4, %r5;
    add.s32 %r2, %r0, %r1;
    st.global.s32 [%rd3], %r2;
    bra if_merge_4;
if_merge_4:
    ret;
}

