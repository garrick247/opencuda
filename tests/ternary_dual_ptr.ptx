.version 9.0
.target sm_120
.address_size 64

.visible .entry ternary_dual_ptr(
    .param .u64 a, .param .u64 b, .param .u64 c, .param .s32 n)
{
    .reg .f32 %f<3>;
    .reg .b32 %r<4>;
    .reg .b64 %rd<4>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [a];
    ld.param.u64 %rd1, [b];
    ld.param.u64 %rd2, [c];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    cvt.u64.u32 %rd3, %r1;
    shl.b64 %rd3, %rd3, 2;
    add.u64 %rd0, %rd0, %rd3;
    div.s32 %r3, %r0, 2;
    setp.gt.s32 %p0, %r1, %r3;
    add.u64 %rd1, %rd1, %rd3;
    ld.global.f32 %f0, [%rd1];
    add.u64 %rd2, %rd2, %rd3;
    ld.global.f32 %f1, [%rd2];
    @%p0 mov.f32 %f2, %f0;
    @!%p0 mov.f32 %f2, %f1;
    st.global.f32 [%rd0], %f2;
    ret;
}
