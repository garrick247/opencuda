.version 9.0
.target sm_120
.address_size 64

.visible .entry mandelbrot_iter(
    .param .u64 out, .param .u64 cx, .param .u64 cy, .param .s32 max_iter, .param .s32 n)
{
    .reg .f32 %f<1>;
    .reg .b32 %r<3>;
    .reg .b64 %rd<6>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [cx];
    ld.param.u64 %rd2, [cy];
    ld.param.s32 %r0, [max_iter];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    cvt.s32.u32 %r2, %r1;
    setp.lt.s32 %p0, %r2, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    shl.b32 %r0, %r2, 2;
    cvt.s64.s32 %rd4, %r0;
    add.u64 %rd3, %rd1, %rd4;
    ld.global.f32 %f0, [%rd3];
    add.u64 %rd1, %rd2, %rd4;
    ld.global.f32 %f0, [%rd1];
    bra while_exit_11;
if_merge_4:
    ret;
while_exit_11:
    shl.b32 %r1, %r2, 2;
    cvt.s64.s32 %rd5, %r1;
    add.u64 %rd3, %rd0, %rd5;
    st.global.s32 [%rd3], 0;
    bra if_merge_4;
}
