.version 9.0
.target sm_120
.address_size 64

.visible .entry smem_test(
    .param .u64 out, .param .u64 in)
{
    .shared .f32 smem[256];
    .reg .f32 %f<1>;
    .reg .b32 %r<2>;
    .reg .b64 %rd<5>;
    .reg .pred %p<1>;

    mov.u64 %rd1, smem;
entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd2, [in];
    mov.u32 %r0, %tid.x;
    shl.b32 %r1, %r0, 2;
    cvt.u64.u32 %rd4, %r1;
    add.u64 %rd3, %rd1, %rd4;
    add.u64 %rd1, %rd2, %rd4;
    ld.global.f32 %f0, [%rd1];
    st.shared.f32 [%rd3], %f0;
    bar.sync 0;
    add.u64 %rd2, %rd0, %rd4;
    ld.shared.f32 %f0, [%rd3];
    st.global.f32 [%rd2], %f0;
    ret;
}
