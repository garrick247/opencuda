    bra if_merge_4;
if_true_2:
    setp.gt.s32 %p0, %r1, 0;
    @%p0 mov.s32 %r1, 10;
    @!%p0 mov.s32 %r1, -10;
    mov.s32 %r2, %r1;
    mov.s32 %r3, 0;
    bra for_cond_8;
if_merge_4:
    ret;
for_cond_8:
    setp.lt.s32 %p0, %r3, %r0;
    @%p0 bra for_body_9;
    bra for_exit_11;
for_body_9:
    shl.b32 %r1, %r3, 2;
    cvt.s64.s32 %rd3, %r1;
    add.u64 %rd2, %rd1, %rd3;
    ld.global.s32 %r1, [%rd2];
    add.s32 %r4, %r2, %r1;
    mov.s32 %r2, %r4;
    bra for_inc_10;
for_inc_10:
    add.s32 %r1, %r3, 1;
    mov.s32 %r3, %r1;
    bra for_cond_8;
for_exit_11:
