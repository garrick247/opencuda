.visible .entry three_loops(
    .param .u64 out)
{
    .reg .b32 %r<5>;
    .reg .b64 %rd<2>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    mov.u32 %r0, %tid.x;
    cvt.s32.u32 %r1, %r0;
    setp.eq.s32 %p0, %r1, 0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    mov.s32 %r0, 0;
    bra for_cond_5;
if_merge_4:
    ret;
for_cond_5:
    add.s32 %r1, %r0, 1;
    add.s32 %r2, %r1, 2;
    add.s32 %r1, %r2, 3;
    mov.s32 %r0, %r1;
    bra for_exit_8;
for_exit_8:
    mov.s32 %r2, 1;
    bra for_cond_9;
for_cond_9:
    shl.b32 %r1, %r2, 1;
    mul.lo.s32 %r3, %r1, 3;
    shl.b32 %r1, %r3, 2;
    mov.s32 %r2, %r1;
    bra for_exit_12;
for_exit_12:
    mov.s32 %r3, 0;
    bra for_cond_13;
for_cond_13:
    add.s32 %r1, %r3, 1;
    add.s32 %r4, %r1, 4;
    add.s32 %r1, %r4, 9;
    mov.s32 %r3, %r1;
    bra for_exit_16;
for_exit_16:
    st.global.s32 [%rd0], %r0;
    add.u64 %rd1, %rd0, 4;
    st.global.s32 [%rd1], %r2;
    add.u64 %rd1, %rd0, 8;
    st.global.s32 [%rd1], %r3;
    bra if_merge_4;
}

.visible .entry loop_then_cond(
    .param .u64 out, .param .u64 in, .param .s32 n, .param .s32 threshold)
{
    .reg .b32 %r<6>;
    .reg .b64 %rd<4>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [in];
    ld.param.s32 %r0, [n];
    ld.param.s32 %r1, [threshold];
