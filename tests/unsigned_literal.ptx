.version 9.0
.target sm_120
.address_size 64

.visible .entry unsigned_literal_test(
    .param .u64 out, .param .s32 n)
{
    .reg .b32 %r<3>;
    .reg .b64 %rd<3>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %tid.x;
    cvt.u32.s32 %r2, %r0;
    setp.lt.u32 %p0, %r1, %r2;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    shl.b32 %r0, %r1, 2;
    cvt.u64.u32 %rd2, %r0;
    add.u64 %rd1, %rd0, %rd2;
    st.global.u32 [%rd1], 5;
    bra if_merge_4;
if_merge_4:
    ret;
}
