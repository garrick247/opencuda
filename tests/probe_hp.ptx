switch_exit_5:
    shl.b32 %r3, %r2, 2;
    cvt.s64.s32 %rd4, %r3;
    add.u64 %rd1, %rd0, %rd4;
    st.global.s32 [%rd1], %r0;
    bra if_merge_4;
case_6:
    or.b32 %r4, %r0, 4;
    mov.s32 %r0, %r4;
    bra case_8;
case_8:
    or.b32 %r5, %r0, 2;
    mov.s32 %r0, %r5;
