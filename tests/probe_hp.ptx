default_11:
    mov.s32 %r0, 0;
    bra switch_exit_5;
switch_dispatch_12:
    setp.eq.s32 %p0, %r1, 7;
    @%p0 bra case_6;
    bra switch_next_13;
switch_next_13:
    setp.eq.s32 %p0, %r1, 6;
    @%p0 bra case_8;
    bra switch_next_14;
switch_next_14:
    setp.eq.s32 %p0, %r1, 5;
    @%p0 bra case_8;
    bra switch_next_15;
switch_next_15:
