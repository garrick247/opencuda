    cvt.s64.s32 %rd3, %r0;
    add.u64 %rd2, %rd1, %rd3;
    ld.global.s32 %r1, [%rd2];
    mul.lo.s32 %r0, %r1, 3;
    add.s32 %r1, %r0, 1;
    div.s32 %r0, %r1, 2;
    rem.s32 %r3, %r1, 2;
    add.s32 %r1, %r0, %r3;
    setp.gt.s32 %p0, %r1, 100;
    sub.s32 %r0, %r1, 100;
    @%p0 bra tern_true_5;
    bra tern_false_6;
if_merge_4:
    ret;
tern_true_5:
    mov.s32 %r3, %r0;
    bra tern_merge_7;
tern_false_6:
    mov.s32 %r3, %r1;
    bra tern_merge_7;
tern_merge_7:
    shr.s32 %r4, %r3, 4;
    xor.b32 %r5, %r3, %r4;
    and.b32 %r3, %r5, 255;
    shl.b32 %r4, %r2, 2;
    cvt.s64.s32 %rd4, %r4;
    add.u64 %rd1, %rd0, %rd4;
    st.global.s32 [%rd1], %r3;
    bra if_merge_4;
}

.visible .entry inplace_update(
