.version 9.0
.target sm_120
.address_size 64

.visible .entry point_in_box(
    .param .u64 out, .param .u64 xs, .param .u64 ys, .param .f32 x0, .param .f32 y0, .param .f32 x1, .param .f32 y1, .param .s32 n)
{
    .reg .f32 %f<6>;
