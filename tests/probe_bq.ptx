    add.u64 %rd4, %rd2, %rd5;
    ld.global.f32 %f5, [%rd4];
    setp.ge.f32 %p0, %f4, %f0;
    setp.le.f32 %p1, %f4, %f1;
    and.pred %p2, %p0, %p1;
    setp.ge.f32 %p0, %f5, %f2;
    and.pred %p1, %p2, %p0;
    setp.le.f32 %p2, %f5, %f3;
    and.pred %p0, %p1, %p2;
    @%p0 bra tern_true_8;
