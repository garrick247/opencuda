.version 9.0
.target sm_120
.address_size 64

.visible .entry mixed_math(
    .param .u64 out, .param .u64 a, .param .u64 b)
{
    .reg .f32 %f<2>;
    .reg .b32 %r<2>;
    .reg .b64 %rd<4>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [a];
    ld.param.u64 %rd2, [b];
    mov.u32 %r0, %tid.x;
    cvt.s32.u32 %r1, %r0;
    shl.b32 %r0, %r1, 2;
    cvt.s64.s32 %rd3, %r0;
    add.u64 %rd1, %rd1, %rd3;
    ld.global.f32 %f0, [%rd1];
    mul.f32 %f1, %f0, 0f40000000;
    add.f32 %f0, %f1, 0f3F800000;
    add.u64 %rd0, %rd0, %rd3;
    st.global.f32 [%rd0], %f0;
    ret;
}
