.version 9.0
.target sm_120
.address_size 64

.visible .entry cmp_type_test(
    .param .u64 out, .param .s32 n, .param .u32 limit)
{
    .reg .b32 %r<4>;
    .reg .b64 %rd<4>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.s32 %r0, [n];
    ld.param.u32 %r1, [limit];
    mov.u32 %r2, %tid.x;
    cvt.u32.s32 %r3, %r0;
    setp.lt.u32 %p0, %r2, %r3;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    setp.lt.u32 %p0, %r2, %r1;
    @%p0 bra if_true_5;
    bra if_false_6;
if_merge_4:
    setp.ne.u32 %p0, 4294967295, 0;
    @%p0 bra if_true_8;
    bra if_merge_10;
if_true_5:
    shl.b32 %r0, %r2, 2;
    cvt.u64.u32 %rd2, %r0;
    add.u64 %rd1, %rd0, %rd2;
    st.global.s32 [%rd1], 1;
    bra if_merge_4;
if_false_6:
    shl.b32 %r1, %r2, 2;
    cvt.u64.u32 %rd3, %r1;
    add.u64 %rd1, %rd0, %rd3;
    st.global.s32 [%rd1], 0;
    bra if_merge_4;
if_true_8:
    st.global.s32 [%rd0], 2;
    bra if_merge_10;
if_merge_10:
    ret;
}
