    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [a];
    ld.param.u64 %rd2, [b];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %ctaid.x;
    mov.u32 %r2, %ntid.x;
    mul.lo.u32 %r3, %r1, %r2;
    mov.u32 %r1, %tid.x;
    add.u32 %r2, %r3, %r1;
    cvt.s32.u32 %r3, %r2;
    setp.lt.s32 %p0, %r3, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    shl.b32 %r1, %r3, 2;
    cvt.s64.s32 %rd3, %r1;
    add.u64 %rd1, %rd1, %rd3;
    ld.global.f32 %f0, [%rd1];
    mul.f32 %f1, 0f3C23D70A, %f0;
    add.f32 %f2, %f1, 0f3CA3D70A;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3CF5C28F;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3D23D70A;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3D4CCCCD;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3D75C28F;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3D8F5C29;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3DA3D70A;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3DB851EC;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3DCCCCCD;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3DE147AE;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3DF5C28F;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3E051EB8;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f2, %f1, 0f3E0F5C29;
    mul.f32 %f1, %f2, %f0;
    add.f32 %f0, %f1, 0f3E19999A;
    add.u64 %rd0, %rd0, %rd3;
    st.global.f32 [%rd0], %f0;
    bra if_merge_4;
if_merge_4:
    ret;
}

.visible .entry bench_nbody(
    .param .u64 out, .param .u64 a, .param .u64 b, .param .s32 n)
{
    .reg .f32 %f<9>;
    .reg .b32 %r<5>;
    .reg .b64 %rd<7>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [a];
    ld.param.u64 %rd2, [b];
    ld.param.s32 %r0, [n];
    mov.u32 %r1, %ctaid.x;
    mov.u32 %r2, %ntid.x;
    mul.lo.u32 %r3, %r1, %r2;
    mov.u32 %r1, %tid.x;
    add.u32 %r2, %r3, %r1;
    cvt.s32.u32 %r3, %r2;
    setp.lt.s32 %p0, %r3, %r0;
    @%p0 bra if_true_2;
    bra if_merge_4;
if_true_2:
    mov.f32 %f0, 0f00000000;
    mov.f32 %f1, 0f00000000;
    shl.b32 %r1, %r3, 2;
    cvt.s64.s32 %rd4, %r1;
    add.u64 %rd3, %rd1, %rd4;
    ld.global.f32 %f2, [%rd3];
    add.u64 %rd3, %rd2, %rd4;
    ld.global.f32 %f3, [%rd3];
    mov.s32 %r2, 0;
    bra for_cond_5;
if_merge_4:
    ret;
for_cond_5:
    setp.lt.s32 %p0, %r2, 64;
    @%p0 bra for_body_6;
    bra for_exit_8;
for_body_6:
    rem.s32 %r1, %r2, %r0;
    shl.b32 %r4, %r1, 2;
    cvt.s64.s32 %rd5, %r4;
    add.u64 %rd3, %rd1, %rd5;
    ld.global.f32 %f4, [%rd3];
    sub.f32 %f5, %f4, %f2;
    add.u64 %rd3, %rd2, %rd5;
    ld.global.f32 %f4, [%rd3];
    sub.f32 %f6, %f4, %f3;
    mul.f32 %f4, %f5, %f5;
    mul.f32 %f7, %f6, %f6;
    add.f32 %f8, %f4, %f7;
    add.f32 %f4, %f8, 0f3A83126F;
    rsqrt.approx.f32 %f7, %f4;
    mul.f32 %f8, %f7, %f7;
    mul.f32 %f4, %f8, %f7;
    mul.f32 %f7, %f5, %f4;
    add.f32 %f8, %f0, %f7;
    mul.f32 %f5, %f6, %f4;
    add.f32 %f7, %f1, %f5;
    mov.f32 %f0, %f8;
    mov.f32 %f1, %f7;
    bra for_inc_7;
for_inc_7:
    add.s32 %r1, %r2, 1;
    mov.s32 %r2, %r1;
    bra for_cond_5;
for_exit_8:
    shl.b32 %r4, %r3, 2;
    cvt.s64.s32 %rd6, %r4;
    add.u64 %rd3, %rd0, %rd6;
    add.f32 %f6, %f0, %f1;
    st.global.f32 [%rd3], %f6;
    bra if_merge_4;
}

.visible .entry bench_mandelbrot(
    .param .u64 out, .param .u64 a, .param .u64 b, .param .s32 n)
{
    .reg .f32 %f<9>;
    .reg .b32 %r<5>;
    .reg .b64 %rd<6>;
    .reg .pred %p<2>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [a];
    ld.param.u64 %rd2, [b];
