    add.f32 %f6, %f4, %f5;
    setp.lt.f32 %p0, %f6, 0f40800000;
    @%p0 bra land_rhs_8;
    bra land_skip_9;
while_body_6:
    mul.f32 %f5, %f2, %f2;
    mul.f32 %f6, %f3, %f3;
    sub.f32 %f7, %f5, %f6;
    add.f32 %f6, %f7, %f0;
    mul.f32 %f7, 0f40000000, %f2;
    mul.f32 %f8, %f7, %f3;
    add.f32 %f7, %f8, %f1;
    add.s32 %r2, %r0, 1;
    mov.f32 %f2, %f6;
    mov.f32 %f3, %f7;
    mov.s32 %r0, %r2;
