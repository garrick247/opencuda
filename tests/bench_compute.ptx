land_rhs_8:
    setp.lt.s32 %p0, %r0, 256;
    selp.s32 %r4, 1, 0, %p0;
    mov.s32 %r2, %r4;
    bra land_merge_10;
land_skip_9:
    mov.s32 %r2, 0;
    bra land_merge_10;
land_merge_10:
    setp.ne.s32 %p1, %r2, 0;
    @%p1 bra while_body_6;
